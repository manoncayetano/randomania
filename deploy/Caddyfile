{{DOMAIN}} {
    encode gzip

    handle /api/* {
        uri strip_prefix /api
        reverse_proxy 127.0.0.1:8000
    }

    handle /media/* {
        reverse_proxy 127.0.0.1:8000
    }

    handle {
        root * /opt/randomania/frontend/dist
        try_files {path} /index.html
        file_server
    }
}
