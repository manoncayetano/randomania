# Copier ce fichier en ".env" et remplir les valeurs (le ".env" n'est jamais commité).
# Aucune variable définie => l'appli tourne en local avec SQLite + fichiers sur disque,
# comme avant (aucun changement de comportement).

# --- Base de données Postgres (ex : Supabase) ---
# Format : postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# --- Stockage fichiers Supabase Storage ---
# URL du projet Supabase (ex : https://xxxxx.supabase.co)
SUPABASE_URL=
# Clé "service_role" (Project Settings > API) — jamais la clé "anon"/publique.
SUPABASE_SERVICE_KEY=
# Nom du bucket Storage (le créer au préalable, en public, dans le dashboard Supabase).
SUPABASE_BUCKET=randomania

# --- Cookies / CORS ---
# true une fois le backend servi en HTTPS (obligatoire pour un cookie cross-domaine).
COOKIE_SECURE=false
# Origine exacte du frontend déployé (ex : https://randomania.vercel.app).
FRONTEND_ORIGIN=http://localhost:5173
